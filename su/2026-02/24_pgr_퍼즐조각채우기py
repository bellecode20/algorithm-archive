from collections import defaultdict, deque

N = 0
dr = [-1, 0, 1, 0]
dc = [0, 1, 0, -1]
answer = -1

def bfs(sr, sc, visited, graph, target):
    group = []
    visited[(sr, sc)] = True
    queue = deque([(sr, sc)])
    group.append([sr, sc])
    
    while queue:
        r, c = queue.popleft()
        group.append([r, c])
        for i in range(4):
            nr, nc = r + dr[i], c + dc[i]
            if nr < 0 or nc < 0 or nr >= N or nc >= N:
                continue
            if visited[(nr, nc)] or graph[nr][nc] != target:
                continue
            visited[(nr, nc)] = True
            queue.append((nr, nc))
            
    return group

