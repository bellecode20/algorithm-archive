from collections import defaultdict, deque

N = 0
dr = [-1, 0, 1, 0]
dc = [0, 1, 0, -1]
answer = 0

def bfs(sr, sc, visited, graph, target):
    group = []
    visited[(sr, sc)] = True
    queue = deque([(sr, sc)])
    
    while queue:
        r, c = queue.popleft()
        group.append([r, c])
        for i in range(4):
            nr, nc = r + dr[i], c + dc[i]
            if nr < 0 or nc < 0 or nr >= N or nc >= N:
                continue
            if visited[(nr, nc)] or graph[nr][nc] != target:
                continue
            visited[(nr, nc)] = True
            queue.append((nr, nc))
            
    return group


def normalize(piece):
    min_row = min(p[0] for p in piece)
    min_col = min(p[1] for p in piece)
    
    sorted_pieces = sorted((p[0] - min_row, p[1] - min_col) for p in piece)
    
    return sorted_pieces
    

def find_piece(target, graph):
    global N
    
    li = []
    visited = defaultdict(bool)
    
    # 모든 칸을 리스트에 넣기
    for r in range(N):
        for c in range(N):
            if graph[r][c] == target and not visited[(r, c)]:
                piece = bfs(r, c, visited, graph, target)  # 해당 시작점과 연결된 모든 조각들을 리스트로 리턴
                li.append(normalize(piece))

    return li


def rotate(puzzle):
    li = []
    for row, col in puzzle:
        li.append([col, N - 1 - row])
    return normalize(li)


def solution(game_board, table):
    global N, answer

    # 1. 조각 추출
    N = len(game_board)
    blanks = find_piece(0, game_board)
    puzzles = find_piece(1, table)

    used = [0] * len(puzzles)
    

    # 2. 회전 및 비교
    for blank in blanks:
        found = False
        
        # 빈칸마다 퍼즐 확인하기
        for i, puzzle in enumerate(puzzles):
            if found:
                break
            if used[i] or len(puzzle) != len(blank):
                continue
            
            # 회전시키기
            cur_puzzle = puzzle

            for _ in range(4):
                # 90도 회전
                if cur_puzzle == blank:
                    found = True
                    answer += len(cur_puzzle)
                    used[i] = 1
                    break
                    
                cur_puzzle = rotate(cur_puzzle)
                
    
    return answer